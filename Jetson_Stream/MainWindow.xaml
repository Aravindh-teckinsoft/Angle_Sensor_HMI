<Window x:Class="Jetson_Stream.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jetson Dashboard"
        Height="600" Width="1000"
        Background="#0F172A">

    <!-- ===================== STYLES ===================== -->
    <Window.Resources>

        <!-- Modern Blue Button -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Width" Value="55"/>
            <Setter Property="Height" Value="55"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="30">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3B82F6"/>
                            </Trigger>

                            <!-- Press -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2563EB"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#243447"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="10"/>
        </Style>

        <!-- Label Style -->
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CBD5F1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="10"
                        Padding="{TemplateBinding Padding}">

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3B82F6"/>
                            </Trigger>

                            <!-- Press -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2563EB"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ===================== LAYOUT ===================== -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Background="#1E293B">
                <TextBlock Text="{Binding FpsText, StringFormat=FPS: {0}}"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="15,0"
                           FontSize="14"/>
            </Border>

            <!-- VIDEO AREA -->
            <Border Grid.Row="1"
                    Background="#0B1220"
                    Margin="10"
                    CornerRadius="10">
                <Image x:Name="VideoImage"
                       Stretch="Uniform"/>
            </Border>

            <!-- CONTROL BAR -->
            <Grid Grid.Row="2">
                <Border Background="#1E293B"
                        CornerRadius="40"
                        Padding="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                    <StackPanel Orientation="Horizontal">

                        <Button Content="▶"
                                Style="{StaticResource ModernButton}"
                                Click="Start_Click"/>

                        <Button Content="⏸"
                                Style="{StaticResource ModernButton}"
                                Click="Pause_Click"/>

                        <Button Content="⏹"
                                Style="{StaticResource ModernButton}"
                                Click="Stop_Click"/>

                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- RIGHT PANEL -->
        <Border Grid.Column="1" Style="{StaticResource Card}">

            <StackPanel>

                <!-- TITLE -->
                <TextBlock Text="Controls"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,10"/>

                <!-- Y START -->
                <StackPanel Margin="0,10">
                    <TextBlock Text="Y-Start"
                               Style="{StaticResource LabelText}"/>

                    <Slider x:Name="Slider1"
                            Minimum="0"
                            Maximum="100"
                            Value="50"/>

                    <TextBlock Text="{Binding ElementName=Slider1, Path=Value, StringFormat=F0}"
                               HorizontalAlignment="Right"
                               Foreground="White"/>
                </StackPanel>

                <!-- Y END -->
                <StackPanel Margin="0,10">
                    <TextBlock Text="Y-End"
                               Style="{StaticResource LabelText}"/>

                    <Slider x:Name="Slider2"
                            Minimum="0"
                            Maximum="100"
                            Value="25"/>

                    <TextBlock Text="{Binding ElementName=Slider2, Path=Value, StringFormat=F0}"
                               HorizontalAlignment="Right"
                               Foreground="White"/>
                </StackPanel>

                <!-- MODE -->
                <StackPanel Margin="0,10">
                    <TextBlock Text="Mode"
                               Style="{StaticResource LabelText}"/>

                    <ComboBox Height="30"
                              SelectedIndex="0"
                              Background="#1E293B"
                              Foreground="Black"
                              BorderBrush="#3B82F6">
                        <ComboBoxItem Content="Custom"/>
                        <ComboBoxItem Content="Default"/>
                    </ComboBox>
                </StackPanel>

                <!-- ACTION BUTTONS -->
                <UniformGrid Columns="2" Margin="0,20,0,0">

                    <Button Content="Default" Margin="5" Background="#1E293B" 
                            Foreground="White"
                            Style="{StaticResource RoundedButton}"/>
                    <Button Content="Save" Margin="5" Background="#1E293B" 
                            Foreground="White"
                            Style="{StaticResource RoundedButton}"/>
                    <Button Content="Apply" Margin="5" Background="#1E293B" 
                            Foreground="White"
                            Style="{StaticResource RoundedButton}"
                            Click="ApplyParams_Click"/>
                    <Button Content="Run" Margin="5" Background="#1E293B" 
                            Foreground="White"
                            Style="{StaticResource RoundedButton}"/>

                </UniformGrid>

            </StackPanel>
        </Border>

    </Grid>
</Window>